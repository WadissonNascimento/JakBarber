generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductCategory {
  BEVERAGE
  SHELF
  OTHER
}

enum ExtraCategory {
  BEVERAGE
  SHELF
  OTHER
}

model Shop {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  primaryDomain       String?  @unique
  isDefault           Boolean  @default(false)
  isActive            Boolean  @default(true)
  metadataTitle       String?
  metadataDescription String?
  whatsappNumber      String?
  instagramUrl        String?
  addressLine         String?
  businessHours       String?
  logoPath            String?
  faviconPath         String?
  brandColor          String?
  brandColorStrong    String?
  brandColorMuted     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  users                    User[]
  pendingRegistrations     PendingRegistration[]
  passwordResetRequests    PasswordResetRequest[]
  services                 Service[]
  appointments             Appointment[]
  appointmentServices      AppointmentService[]
  reviews                  Review[]
  barberAvailabilities     BarberAvailability[]
  barberBlocks             BarberBlock[]
  recurringBarberBlocks    RecurringBarberBlock[]
  clientNotes              ClientNote[]
  customerProfiles         CustomerProfile[]
  products                 Product[]
  barberServiceCommissions BarberServiceCommission[]
  extraProducts            ExtraProduct[]
  appointmentItems         AppointmentItem[]
  orders                   Order[]
  orderItems               OrderItem[]
  coupons                  Coupon[]
  stockMovements           StockMovement[]
  extraStockMovements      ExtraStockMovement[]
  barberPayouts            BarberPayout[]
  emailDeliveryLogs        EmailDeliveryLog[]

  @@index([isActive, isDefault])
}

model User {
  id            String    @id @default(cuid())
  shopId        String    @default("shop_jak_barber")
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("CUSTOMER")
  phone         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  accounts Account[]
  sessions Session[]

  customerAppointments     Appointment[]             @relation("CustomerAppointments")
  barberAppointments       Appointment[]             @relation("BarberAppointments")
  customerReviews          Review[]                  @relation("CustomerReviews")
  barberReviews            Review[]                  @relation("BarberReviews")
  barberServices           Service[]                 @relation("BarberServices")
  barberServiceCommissions BarberServiceCommission[]
  barberAvailabilities     BarberAvailability[]
  barberBlocks             BarberBlock[]
  recurringBarberBlocks    RecurringBarberBlock[]
  barberPayouts            BarberPayout[]
  barberClientNotes        ClientNote[]              @relation("BarberClientNotes")
  customerClientNotes      ClientNote[]              @relation("CustomerClientNotes")
  customerProfile          CustomerProfile?          @relation("CustomerProfileOwner")
  preferredByProfiles      CustomerProfile[]         @relation("PreferredBarber")
  orders                   Order[]                   @relation("CustomerOrders")
  emailDeliveryLogs        EmailDeliveryLog[]        @relation("EmailDeliveryRecipient")

  @@unique([id, shopId])
  @@index([shopId, role, isActive])
  @@index([shopId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailDeliveryLog {
  id              String    @id @default(cuid())
  shopId          String    @default("shop_jak_barber")
  recipientUserId String?
  recipientEmail  String
  template        String
  eventKey        String
  status          String    @default("PENDING")
  attempts        Int       @default(0)
  subject         String
  lastError       String?
  metadata        Json?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  shop      Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  recipient User? @relation("EmailDeliveryRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@unique([shopId, template, eventKey, recipientEmail])
  @@index([shopId, recipientUserId, createdAt])
  @@index([shopId, status, createdAt])
}

model PendingRegistration {
  id           String   @id @default(cuid())
  shopId       String   @default("shop_jak_barber")
  name         String
  email        String   @unique
  phone        String?
  passwordHash String
  role         String   @default("CUSTOMER")
  code         String
  expiresAt    DateTime
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([id, shopId])
  @@index([shopId, email, expiresAt])
}

model PasswordResetRequest {
  id        String   @id @default(cuid())
  shopId    String   @default("shop_jak_barber")
  email     String   @unique
  code      String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([id, shopId])
  @@index([shopId, email, expiresAt])
}

model Service {
  id              String   @id @default(cuid())
  shopId          String   @default("shop_jak_barber")
  barberId        String?
  name            String
  description     String?
  price           Float
  duration        Int
  bufferAfter     Int      @default(0)
  commissionType  String   @default("PERCENT")
  commissionValue Float    @default(40)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop   Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  barber User? @relation("BarberServices", fields: [barberId], references: [id], onDelete: Cascade)

  appointmentItems  AppointmentService[]
  barberCommissions BarberServiceCommission[]

  @@unique([id, shopId])
  @@index([shopId, isActive, name])
  @@index([shopId, barberId, isActive])
}

model Appointment {
  id             String    @id @default(cuid())
  shopId         String    @default("shop_jak_barber")
  publicId       Int
  customerId     String
  barberId       String
  date           DateTime
  status         String    @default("PENDING")
  notes          String?
  reminderSentAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  shop     Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer User @relation("CustomerAppointments", fields: [customerId], references: [id], onDelete: Cascade)
  barber   User @relation("BarberAppointments", fields: [barberId], references: [id], onDelete: Cascade)

  services AppointmentService[]
  items    AppointmentItem[]
  review   Review?

  @@unique([id, shopId])
  @@unique([shopId, publicId])
  @@index([shopId, customerId])
  @@index([shopId, customerId, date])
  @@index([shopId, barberId, status])
  @@index([shopId, barberId, date])
  @@index([shopId, date])
  @@index([shopId, status, reminderSentAt, date])
}

model AppointmentService {
  id                      String   @id @default(cuid())
  shopId                  String   @default("shop_jak_barber")
  appointmentId           String
  serviceId               String
  orderIndex              Int      @default(0)
  nameSnapshot            String
  priceSnapshot           Float
  durationSnapshot        Int
  bufferAfter             Int      @default(0)
  commissionTypeSnapshot  String   @default("PERCENT")
  commissionValueSnapshot Float    @default(40)
  barberPayoutSnapshot    Float    @default(0)
  shopRevenueSnapshot     Float    @default(0)
  createdAt               DateTime @default(now())

  shop        Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([id, shopId])
  @@index([shopId, appointmentId, orderIndex])
  @@index([shopId, serviceId])
}

model Review {
  id            String   @id @default(cuid())
  shopId        String   @default("shop_jak_barber")
  appointmentId String   @unique
  customerId    String
  barberId      String
  rating        Int
  comment       String
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop        Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  customer    User        @relation("CustomerReviews", fields: [customerId], references: [id], onDelete: Cascade)
  barber      User        @relation("BarberReviews", fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([id, shopId])
  @@index([shopId, customerId])
  @@index([shopId, barberId])
  @@index([shopId, isVisible, createdAt])
}

model BarberAvailability {
  id        String   @id @default(cuid())
  shopId    String   @default("shop_jak_barber")
  barberId  String
  weekDay   Int
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop   Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  barber User @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([id, shopId])
  @@unique([barberId, weekDay])
  @@index([shopId, barberId, weekDay])
}

model BarberBlock {
  id            String   @id @default(cuid())
  shopId        String   @default("shop_jak_barber")
  barberId      String
  startDateTime DateTime
  endDateTime   DateTime
  reason        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop   Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  barber User @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([id, shopId])
  @@index([shopId, barberId, startDateTime])
  @@index([shopId, barberId, endDateTime])
}

model RecurringBarberBlock {
  id        String   @id @default(cuid())
  shopId    String   @default("shop_jak_barber")
  barberId  String
  weekDay   Int
  startTime String
  endTime   String
  reason    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop   Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  barber User @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([id, shopId])
  @@index([shopId, barberId, weekDay, isActive])
  @@index([shopId, barberId, isActive])
}

model ClientNote {
  id         String   @id @default(cuid())
  shopId     String   @default("shop_jak_barber")
  barberId   String
  customerId String
  note       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shop     Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  barber   User @relation("BarberClientNotes", fields: [barberId], references: [id], onDelete: Cascade)
  customer User @relation("CustomerClientNotes", fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([id, shopId])
  @@unique([barberId, customerId])
  @@index([shopId, barberId])
  @@index([shopId, customerId])
}

model CustomerProfile {
  id                String    @id @default(cuid())
  shopId            String    @default("shop_jak_barber")
  customerId        String    @unique
  birthDate         DateTime?
  preferredBarberId String?
  allergies         String?
  preferences       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  shop            Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer        User  @relation("CustomerProfileOwner", fields: [customerId], references: [id], onDelete: Cascade)
  preferredBarber User? @relation("PreferredBarber", fields: [preferredBarberId], references: [id], onDelete: SetNull)

  @@unique([id, shopId])
  @@index([shopId, preferredBarberId])
}

model Product {
  id          String          @id @default(cuid())
  shopId      String          @default("shop_jak_barber")
  name        String
  description String?
  category    ProductCategory @default(OTHER)
  price       Float
  imageUrl    String?
  imagePath   String?         @map("image_path")
  stock       Int             @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  orderItems     OrderItem[]
  stockMovements StockMovement[]

  @@unique([id, shopId])
  @@index([shopId, isActive, createdAt])
}

model BarberServiceCommission {
  id              String   @id @default(cuid())
  shopId          String   @default("shop_jak_barber")
  barberId        String
  serviceId       String
  commissionType  String   @default("PERCENT")
  commissionValue Float    @default(40)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  barber  User    @relation(fields: [barberId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([id, shopId])
  @@unique([barberId, serviceId])
  @@index([shopId, barberId])
  @@index([shopId, serviceId])
}

model ExtraProduct {
  id              String        @id @default(cuid())
  shopId          String        @default("shop_jak_barber")
  name            String
  description     String?
  category        ExtraCategory @default(OTHER)
  price           Float
  commissionType  String        @default("PERCENT")
  commissionValue Float         @default(0)
  imageUrl        String?
  imagePath       String?       @map("image_path")
  stock           Int           @default(0)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  appointmentItems AppointmentItem[]
  stockMovements   ExtraStockMovement[]

  @@unique([id, shopId])
  @@index([shopId, isActive, createdAt])
}

model AppointmentItem {
  id                      String    @id @default(cuid())
  shopId                  String    @default("shop_jak_barber")
  appointmentId           String
  extraProductId          String    @map("productId")
  productNameSnapshot     String
  quantity                Int       @default(1)
  unitPrice               Float
  subtotal                Float
  commissionTypeSnapshot  String    @default("PERCENT")
  commissionValueSnapshot Float     @default(0)
  barberPayoutSnapshot    Float     @default(0)
  shopRevenueSnapshot     Float     @default(0)
  isDelivered             Boolean   @default(false)
  deliveredAt             DateTime?
  createdAt               DateTime  @default(now())

  shop         Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  appointment  Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  extraProduct ExtraProduct @relation(fields: [extraProductId], references: [id], onDelete: Cascade)

  @@unique([id, shopId])
  @@index([shopId, appointmentId])
  @@index([shopId, extraProductId])
}

model Order {
  id              String   @id @default(cuid())
  shopId          String   @default("shop_jak_barber")
  customerId      String
  couponId        String?
  status          String   @default("PENDING")
  trackingCode    String?
  adminApproved   Boolean  @default(false)
  total           Float    @default(0)
  subtotal        Float    @default(0)
  shippingCost    Float    @default(0)
  discountTotal   Float    @default(0)
  shippingZipCode String?
  shippingMethod  String?
  shippingAddress String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop     Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer User        @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Cascade)
  coupon   Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items    OrderItem[]

  @@unique([id, shopId])
  @@index([shopId, customerId])
  @@index([shopId, status])
  @@index([shopId, couponId])
}

model OrderItem {
  id                  String   @id @default(cuid())
  shopId              String   @default("shop_jak_barber")
  orderId             String
  productId           String
  productNameSnapshot String
  quantity            Int      @default(1)
  unitPrice           Float
  createdAt           DateTime @default(now())

  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([id, shopId])
  @@index([shopId, orderId])
  @@index([shopId, productId])
}

model Coupon {
  id            String    @id @default(cuid())
  shopId        String    @default("shop_jak_barber")
  code          String    @unique
  description   String?
  discountType  String
  discountValue Float
  minOrderTotal Float     @default(0)
  maxDiscount   Float?
  expiresAt     DateTime?
  usageLimit    Int?
  timesUsed     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  shop   Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([id, shopId])
  @@index([shopId, code, isActive])
}

model StockMovement {
  id        String   @id @default(cuid())
  shopId    String   @default("shop_jak_barber")
  productId String
  type      String
  quantity  Int
  reason    String?
  createdAt DateTime @default(now())

  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([id, shopId])
  @@index([shopId, productId, createdAt])
  @@index([shopId, type])
}

model ExtraStockMovement {
  id             String   @id @default(cuid())
  shopId         String   @default("shop_jak_barber")
  extraProductId String
  type           String
  quantity       Int
  reason         String?
  createdAt      DateTime @default(now())

  shop         Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  extraProduct ExtraProduct @relation(fields: [extraProductId], references: [id], onDelete: Cascade)

  @@unique([id, shopId])
  @@index([shopId, extraProductId, createdAt])
  @@index([shopId, type])
}

model BarberPayout {
  id              String    @id @default(cuid())
  shopId          String    @default("shop_jak_barber")
  barberId        String
  periodStart     DateTime
  periodEnd       DateTime
  grossRevenue    Float     @default(0)
  commissionTotal Float     @default(0)
  shopNetRevenue  Float     @default(0)
  status          String    @default("OPEN")
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  shop   Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  barber User @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([id, shopId])
  @@unique([barberId, periodStart, periodEnd])
  @@index([shopId, barberId, status])
  @@index([shopId, periodStart, periodEnd])
}
